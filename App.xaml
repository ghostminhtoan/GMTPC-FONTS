<Application x:Class="GMTPC_FONTS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GMTPC_FONTS"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="#4CC2FF" />
            <Setter Property="Background" Value="#232A32" />
            <Setter Property="BorderBrush" Value="#3A444F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="10" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#7FEAFF" />
        </Style>
    </Application.Resources>
</Application>
