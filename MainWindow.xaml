<Window x:Class="GMTPC_FONTS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GMTPC_FONTS"
        mc:Ignorable="d"
        Title="GMTPC Fonts"
        Width="720"
        Height="390"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#111418"
        Foreground="#F3F6FA"
        FontFamily="Segoe UI Variable, Segoe UI"
        ShowInTaskbar="True"
        Loaded="Window_Loaded">
    <Border Padding="28" Background="#111418">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Installing..."
                       FontSize="24"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <ProgressBar x:Name="InstallProgress"
                         Grid.Row="2"
                         Minimum="0"
                         Maximum="100"
                         Value="0" />

            <TextBlock x:Name="ProgressText"
                       Grid.Row="4"
                       Text="Preparing"
                       FontSize="12"
                       Foreground="#AAB4C0"
                       HorizontalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="580" />

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus01" Text="01 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus02" Text="02 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus03" Text="03 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus04" Text="04 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus05" Text="05 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus06" Text="06 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus07" Text="07 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus08" Text="08 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Margin="0,0,0,6" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus09" Text="09 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Height="24" Padding="8,0" Background="#151A20" BorderBrush="#2C3540" BorderThickness="1">
                        <TextBlock x:Name="WorkerStatus10" Text="10 Ready" VerticalAlignment="Center" FontSize="11" Foreground="#AAB4C0" TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="PauseButton"
                        Content="Pause"
                        Width="84"
                        Height="30"
                        Margin="0,0,10,0"
                        Click="PauseButton_Click"
                        Background="#252B33"
                        Foreground="#F3F6FA"
                        BorderBrush="#3A444F" />

                <Button x:Name="StopButton"
                        Content="Stop"
                        Width="84"
                        Height="30"
                        Click="StopButton_Click"
                        Background="#3A2227"
                        Foreground="#F3F6FA"
                        BorderBrush="#70414A" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
